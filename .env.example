# =============================================================================
# Kamerka Plus GUI — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control — it contains secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values, then load it:
#   export $(grep -v '^#' .env | xargs)
#
# Or use a tool like python-dotenv / direnv to load it automatically.
# =============================================================================

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------

# Required for production: a long random secret string.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Set to "False" (or leave unset) in production. Set to "True" only for development.
DEBUG=False

# Comma-separated list of hostnames/IPs Django is allowed to serve.
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------

# Shodan paid-account API key (required for searches)
SHODAN_API_KEY=your_shodan_api_key_here

# NIST NVD API key — raises rate limit from 5 to 50 req/30 s (optional)
# Request one at: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your_nvd_api_key_here

# Pastebin API keys for field-agent sync (optional)
# PASTEBIN_API_DEV_KEY=your_unique_developer_api_key
# PASTEBIN_API_USER_NAME=your_pastebin_username
# PASTEBIN_API_USER_PASSWORD=your_pastebin_password

# ---------------------------------------------------------------------------
# Database (leave unset to use the default SQLite database)
# ---------------------------------------------------------------------------

# Uncomment and fill in to use PostgreSQL instead of SQLite:
# DB_NAME=kamerka
# DB_USER=kamerka
# DB_PASSWORD=change_me
# DB_HOST=localhost
# DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# Optional overrides (defaults shown):
# CELERY_BROKER_URL=redis://localhost:6379
# CELERY_RESULT_BACKEND=redis://localhost:6379
# CELERY_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# External tool paths (only needed if the binaries are not on $PATH)
# ---------------------------------------------------------------------------

# KAMERKA_NAABU_BIN=naabu
# KAMERKA_NUCLEI_BIN=nuclei
# KAMERKA_WAPPALYZER_BIN=wappalyzer

# Nmap scan timeout in seconds (default: 300)
# NMAP_MAX_RUNTIME=300

# Naabu port scan defaults
# KAMERKA_NAABU_PORTS=top-100
# KAMERKA_NAABU_TIMEOUT=60
# KAMERKA_NAABU_DISCOVERY_PORTS=1-65535
# KAMERKA_NAABU_DISCOVERY_TIMEOUT=120

# Nuclei scan timeout in seconds (default: 300)
# KAMERKA_NUCLEI_TIMEOUT=300

# ---------------------------------------------------------------------------
# HTTPS / Production security (leave at 0/False for HTTP-only development)
# ---------------------------------------------------------------------------

# Enable HSTS after confirming HTTPS works correctly (recommended: 31536000 = 1 year)
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False

# Redirect plain HTTP to HTTPS (enable only when behind a TLS terminator)
# SECURE_SSL_REDIRECT=False

# Mark session and CSRF cookies as secure (HTTPS-only)
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
