# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.
#
# All variables are read at startup via python-dotenv (settings.py).
# In CI or Docker, set these directly as environment variables instead.

# ── Required ──────────────────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────
# Pastebin integration (send_to_field_agent_task)
PASTEBIN_USER=your_pastebin_username
PASTEBIN_PASSWORD=your_pastebin_password
PASTEBIN_DEV_KEY=your_pastebin_developer_key

# Django secret key (auto-generated at runtime if not set)
# DJANGO_SECRET_KEY=change-me-in-production
